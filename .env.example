# Copy to ".env" and fill in real values for production deploy.
# All variables are consumed by docker-compose.yml.

# ----- Host ports (change if these conflict with services on your host) -----
# MySQL on the host (container always uses 3306 internally)
MYSQL_HOST_PORT=3307
# Backend on the host (container always uses 8080 internally)
BACKEND_HOST_PORT=8081

# ----- MySQL -----
MYSQL_ROOT_PASSWORD=changeme-root
DB_NAME=streamflix_db
# IMPORTANT: do NOT use "root" here — MySQL 8 won't let MYSQL_USER equal root
DB_USERNAME=streamflix
DB_PASSWORD=changeme-app

# ----- Backend -----
# Generate with: openssl rand -base64 32
APP_JWT_SECRET=ChangeMe-Generate-A-Real-256bit-Base64-Secret-Here==
APP_JWT_EXPIRATION_MS=86400000
