# ============================================================================
# StreamFlix .gitignore
# Java (Maven) backend + JavaFX desktop frontend + MySQL database + docs
# ============================================================================

# ---------------------------------------------------------------------------
# Maven build output
# ---------------------------------------------------------------------------
target/
*.jar
*.war
*.ear
*.nar
!.mvn/wrapper/maven-wrapper.jar
.mvn/
mvnw
mvnw.cmd

# Maven-generated release files
release.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
buildNumber.properties
dependency-reduced-pom.xml

# ---------------------------------------------------------------------------
# Compiled Java
# ---------------------------------------------------------------------------
*.class
*.log
hs_err_pid*
replay_pid*

# ---------------------------------------------------------------------------
# Spring Boot
# ---------------------------------------------------------------------------
spring-boot-*.log
*.original

# ---------------------------------------------------------------------------
# Secrets / local configuration — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
application-local.yml
application-local.properties
application-prod.yml
application-prod.properties
*.pem
*.p12
*.jks
*.keystore
src/main/resources/secrets/

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.h2.db
*.mv.db
*.trace.db
*.lock.db
data/
mysql-data/
backups/
*.sql.bak
*.dump

# ---------------------------------------------------------------------------
# IDE — IntelliJ IDEA
# ---------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/

# ---------------------------------------------------------------------------
# IDE — Eclipse / STS
# ---------------------------------------------------------------------------
.project
.classpath
.settings/*
# We DO want to commit the JDT compiler prefs (silences false-positive
# null-analysis hints in VS Code's Java extension)
!.settings/org.eclipse.jdt.core.prefs
.metadata/
.factorypath
.springBeans
.sts4-cache/
bin/

# ---------------------------------------------------------------------------
# IDE — VS Code
# ---------------------------------------------------------------------------
.vscode/
*.code-workspace
.history/

# ---------------------------------------------------------------------------
# IDE — NetBeans
# ---------------------------------------------------------------------------
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# ---------------------------------------------------------------------------
# OS — macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# ---------------------------------------------------------------------------
# OS — Windows
# ---------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---------------------------------------------------------------------------
# OS — Linux
# ---------------------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*

# ---------------------------------------------------------------------------
# Node (used only by the report generator under /report)
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# ---------------------------------------------------------------------------
# Test / coverage / reports
# ---------------------------------------------------------------------------
coverage/
*.lcov
jacoco.exec
*.exec
test-output/
surefire-reports/
failsafe-reports/

# ---------------------------------------------------------------------------
# Logs and temp files
# ---------------------------------------------------------------------------
*.log
*.log.*
logs/
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Build & output directories
# ---------------------------------------------------------------------------
build/
dist/
out/

# ---------------------------------------------------------------------------
# JavaFX runtime images (jlink / jpackage output)
# ---------------------------------------------------------------------------
runtime/
app-image/
*.dmg
*.pkg
*.deb
*.rpm
*.exe
*.msi

# ---------------------------------------------------------------------------
# Documentation build artefacts
# ---------------------------------------------------------------------------
docs/_build/
docs/*.pdf.tmp
~$*.docx
~$*.xlsx
~$*.pptx

# ---------------------------------------------------------------------------
# Project-specific scratch
# ---------------------------------------------------------------------------
/scratch/
/sandbox/
TODO.local.md
NOTES.local.md
